# Password Protection
NEXT_PUBLIC_UPWEGO_PASSWORD=your_password

# Site Configuration
# Base URL of your website (used for Open Graph tags and absolute URLs)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Email Configuration
# Resend API settings for sending contact form emails
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key
# Email address to send from (must be verified in Resend dashboard)
EMAIL_FROM=your_email@yourdomain.com
# Display name for sender (optional - if not set, only email address will be shown)
EMAIL_FROM_NAME=Your Company Name
# Email address to receive contact form submissions
CONTACT_EMAIL_TO=your_contact_email@yourdomain.com
# Subject line for contact form emails
CONTACT_EMAIL_SUBJECT=New Form Submission
